# Test_PrisonersDilemma.gsl
#
# Smoke test: a complete 5-round Prisoner's Dilemma session.
#   Alice (admin account)  →  Prisoner A
#   Bob   (mock account)   →  Prisoner B
#
# Rounds tested:
#   Round 1 — Both Cooperate  (C, C)  → A:+3, B:+3
#   Round 2 — A Defects, B Cooperates (D, C) → A:+5, B:+0
#   Round 3 — Both Defect     (D, D)  → A:+1, B:+1
#   Round 4 — A Cooperates, B Defects (C, D) → A:+0, B:+5
#   Round 5 — Both Cooperate  (C, C)  → A:+3, B:+3
#
# Usage (API mode — no browser required):
#   python manage.py run_gsl Test_PrisonersDilemma.gsl
#
# For browser validation:
#   python manage.py run_gsl Test_PrisonersDilemma.gsl --mode browser
#
# SECURITY NOTE: plaintext password below.
# Replace with: Login admin $ADMIN_PASS display:"Alice"
# -----------------------------------------------------------------------


# --- 1. Session owner login -------------------------------------------

Login admin pass1234 display:"Alice"


# --- 2. Game selection ------------------------------------------------

Select_Game prisoners-dilemma


# --- 3. Create session ------------------------------------------------

Create_Session name:"PD smoke test"


# --- 4. Second player -------------------------------------------------

Add_Player mock display:"Bob"


# --- 5. Role assignments ----------------------------------------------

Assign_role Alice "Prisoner A"
Assign_role Bob   "Prisoner B"


# --- 6. Start the game ------------------------------------------------

Start_game


# --- 7. Verify initial state ------------------------------------------

Assert_phase        playing
Assert_player_count 2
Assert_state        phase  intro
Assert_active_role  "Prisoner A"
Assert_state        round_num  1
Assert_state        scores.0   0
Assert_state        scores.1   0

Assert_view_exists Alice "Prisoner A"
Assert_view_exists Bob   "Prisoner B"


# --- 8. Start the game (intro → choosing) ----------------------------

Op Alice "Start the Game"

Assert_state  phase  choosing
Assert_state  round_num  1
Assert_state  parallel  1


# --- 9. Round 1: Both Cooperate (C, C) --------------------------------
# Expected payoff: A:+3, B:+3  →  cumulative A=3, B=3

Op Alice "Cooperate (Stay Silent)"
Op Bob   "Cooperate (Stay Silent)"

Assert_state  phase  reveal
Assert_state  round_num  1
Assert_state  scores.0   3
Assert_state  scores.1   3
Assert_state  choices.0  0
Assert_state  choices.1  0

Op Alice "Continue"

Assert_state  phase  choosing
Assert_state  round_num  2


# --- 10. Round 2: A Defects, B Cooperates (D, C) ----------------------
# Expected payoff: A:+5, B:+0  →  cumulative A=8, B=3

Op Alice "Defect (Betray Partner)"
Op Bob   "Cooperate (Stay Silent)"

Assert_state  phase  reveal
Assert_state  round_num  2
Assert_state  scores.0   8
Assert_state  scores.1   3
Assert_state  choices.0  1
Assert_state  choices.1  0

Op Alice "Continue"

Assert_state  phase  choosing
Assert_state  round_num  3


# --- 11. Round 3: Both Defect (D, D) ----------------------------------
# Expected payoff: A:+1, B:+1  →  cumulative A=9, B=4

Op Bob   "Defect (Betray Partner)"
Op Alice "Defect (Betray Partner)"

Assert_state  phase  reveal
Assert_state  round_num  3
Assert_state  scores.0   9
Assert_state  scores.1   4
Assert_state  choices.0  1
Assert_state  choices.1  1

Op Bob "Continue"

Assert_state  phase  choosing
Assert_state  round_num  4


# --- 12. Round 4: A Cooperates, B Defects (C, D) ----------------------
# Expected payoff: A:+0, B:+5  →  cumulative A=9, B=9

Op Bob   "Defect (Betray Partner)"
Op Alice "Cooperate (Stay Silent)"

Assert_state  phase  reveal
Assert_state  round_num  4
Assert_state  scores.0   9
Assert_state  scores.1   9
Assert_state  choices.0  0
Assert_state  choices.1  1

Op Alice "Continue"

Assert_state  phase  choosing
Assert_state  round_num  5


# --- 13. Round 5 (final): Both Cooperate (C, C) -----------------------
# Expected payoff: A:+3, B:+3  →  cumulative A=12, B=12

Op Alice "Cooperate (Stay Silent)"
Op Bob   "Cooperate (Stay Silent)"

Assert_state  phase  reveal
Assert_state  round_num  5
Assert_state  scores.0   12
Assert_state  scores.1   12


# --- 14. Final Continue → game_over -----------------------------------

Op Alice "Continue"

Assert_state  phase  game_over
Assert_phase  ended


# --- 15. Final score verification ------------------------------------

Assert_state  scores.0  12
Assert_state  scores.1  12
