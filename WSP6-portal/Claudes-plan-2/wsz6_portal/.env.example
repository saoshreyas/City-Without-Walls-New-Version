# WSZ6 Portal – example environment file
# Copy to .env (or .env.dev for development) and fill in real values.
# Never commit a file containing real secrets.

# Django core
DJANGO_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com

# Internal API shared secret (wsz6-admin <-> wsz6-play)
INTERNAL_API_KEY=CHANGE-ME-IN-PRODUCTION

# Database (production – PostgreSQL)
UARD_DB_NAME=wsz6_uard
UARD_DB_USER=wsz6
UARD_DB_PASSWORD=change-me
UARD_DB_HOST=localhost
UARD_DB_PORT=5432

GDM_DB_NAME=wsz6_gdm
GDM_DB_USER=wsz6
GDM_DB_PASSWORD=change-me
GDM_DB_HOST=localhost
GDM_DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# File-system paths
GAMES_REPO_ROOT=/path/to/games_repo
GDM_ROOT=/path/to/gdm
SOLUZION_LIB_DIR=/path/to/Textual_SZ6

# Production email (required when DEBUG=False)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@address.com
EMAIL_HOST_PASSWORD=app-specific-password
DEFAULT_FROM_EMAIL=noreply@your-domain.com
