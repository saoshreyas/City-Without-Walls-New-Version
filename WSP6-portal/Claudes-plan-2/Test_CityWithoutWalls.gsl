# Test_CityWithoutWalls.gsl
#
# Smoke test: five stakeholder roles, two full policy cycles (10 operators).
# Uses Set_rng_seed for reproducible macro / success rolls (development only).
#
# Usage:
#   cd wsz6_portal && python manage.py run_gsl ../Test_CityWithoutWalls.gsl
#
# SECURITY NOTE: plaintext password below (dev fixture only).


Login admin pass1234 display:"Alice"

Select_Game city-without-walls

Create_Session name:"CWW smoke test"

Add_Player mock display:"Bob"
Add_Player mock display:"Carol"
Add_Player mock display:"Dave"
Add_Player mock display:"Eve"

Assign_role Alice  Neighborhoods
Assign_role Bob    Business
Assign_role Carol  Medical
Assign_role Dave   Shelters
Assign_role Eve    University

Set_rng_seed 42

Start_game

Assert_phase        playing
Assert_player_count 5
Assert_state        phase  intro
Assert_state        current_role_num  0
Assert_active_role  Neighborhoods

Op Alice "Review goals & begin simulation"

Assert_state        phase  playing
Assert_state        current_role_num  0


# --- Round 1 (one moderate operator per role) ---------------------------

Op Alice "Media Campaign: reframe homelessness [public support +6, legal pressure -3]"
Op Bob   "Fund Job Readiness Programs [families -5%, youth -12%, public support +2.2]"
Op Carol "Deploy Mobile Clinics [medical vans +2, chronic homelessness -6%, public support +2.8]"
Op Dave  "Volunteer Training: social workers +3 [social workers +3, public support +1]"
Op Eve   "Research & Program Evaluation [policy momentum +1.5]"

Assert_state  game_round           2
Assert_state  homeless_population  10283
Assert_state  public_support       63.0
Assert_state  legal_pressure       8.5


# --- Round 2 ----------------------------------------------------------

Op Alice "Block New Low-Income Development: NIMBY action [permanent units -50, public support +2, legal pressure +4]"
Op Bob   "Tax Incentives for Affordable Housing [permanent units +120 scheduled, economy index +1.8, public support +1.2]"
Op Carol "Medicaid & Benefits Enrollment Drive [chronic homelessness -7%, policy momentum +1.2]"
Op Dave  "Emergency Expansion: beds +300 [shelter capacity +300 scheduled, families -10%, veterans -12%]"
Op Eve   "Service-Learning & Workforce Integration [social workers +5, youth -10%, public support +1.2]"

Assert_state  game_round           3
Assert_state  homeless_population  9703
Assert_state  public_support       66.4
Assert_state  legal_pressure       14.0

Assert_phase  playing
